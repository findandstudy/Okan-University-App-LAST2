# ─── University Landing Platform — Environment Variables ──────────────────────
# Copy this file to .env on your VPS and fill in real values.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Example for a local DB: postgresql://uni_user:strongpassword@localhost:5432/uni_landing
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# ── Session ───────────────────────────────────────────────────────────────────
# Used to sign session cookies.  Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change-this-to-a-long-random-string

# ── AI API Key Encryption ─────────────────────────────────────────────────────
# AES-256 key used to encrypt AI provider API keys stored in the database.
# Generate ONCE with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# ⚠️  CRITICAL — Back this up to a secure password manager / secrets vault.
# If this key is lost or changed after initial setup, ALL stored AI API keys
# in the database become permanently unrecoverable and must be re-entered
# manually on every tenant.  NEVER rotate this key once it is in production.
ENCRYPTION_KEY=your-64-char-hex-key-here

# ── File Uploads ──────────────────────────────────────────────────────────────
# Absolute path to a directory where uploaded files (logos, images, exports)
# are stored.  Must be outside the repo directory so it survives deployments.
# Create it first:  mkdir -p /var/data/uni-landing/uploads
UPLOADS_DIR=/var/data/uni-landing/uploads

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
