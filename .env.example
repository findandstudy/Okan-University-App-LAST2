# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Session
SESSION_SECRET=change-this-to-a-random-string

# AI API Key Encryption
# IMPORTANT: Generate once with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Store this safely. If lost or changed, all stored AI API keys become unrecoverable and must be re-entered.
ENCRYPTION_KEY=your-64-char-hex-key-here

# Object Storage (set by Replit integration)
DEFAULT_OBJECT_STORAGE_BUCKET_ID=
PRIVATE_OBJECT_DIR=
PUBLIC_OBJECT_SEARCH_PATHS=
