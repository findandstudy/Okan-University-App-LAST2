# ─── Caddy Configuration — University Landing Platform ────────────────────────
#
# Copy this file to /etc/caddy/Caddyfile (or wherever Caddy reads its config)
# and edit the placeholder values for your setup.
#
# Requirements:
#   - Caddy 2.7+ with on-demand TLS support
#   - The app must be running on localhost:5000 (see ecosystem.config.cjs)
#   - Each tenant domain must be added via the admin panel BEFORE Caddy
#     issues a certificate for it; the /api/internal/verify-domain endpoint
#     acts as the abuse-prevention gate for on-demand TLS.
#
# How on-demand TLS works here:
#   When a new domain hits Caddy for the first time, Caddy calls the `ask`
#   URL before issuing a Let's Encrypt certificate.  The app returns 200 only
#   for domains that exist in the tenant_domains table, so rogue domains never
#   get a certificate.
#
# ─── Global options ───────────────────────────────────────────────────────────
{
  # Email for Let's Encrypt account (required for cert notifications)
  email admin@yourdomain.com

  on_demand_tls {
    # Ask the app whether this domain is allowed before issuing a cert.
    # The app returns 200 for known domains, 403 for unknown ones.
    ask http://localhost:5000/api/internal/verify-domain?domain={host}

    # Throttle certificate issuance to avoid LE rate limits
    interval 2m
    burst     5
  }
}

# ─── Catch-all: serve any registered tenant domain ───────────────────────────
# This block matches every incoming hostname.  Caddy will only issue a
# certificate for hosts that pass the `ask` check above.
:443 {
  tls {
    on_demand
  }

  # Serve uploaded files (logos, images, exports) directly from disk.
  # Adjust the path to match your UPLOADS_DIR setting.
  handle_path /objects/uploads/* {
    root * /var/data/uni-landing/uploads
    file_server
  }

  # Proxy everything else to the Node.js app
  reverse_proxy localhost:5000 {
    header_up Host {host}
    header_up X-Real-IP {remote_host}
    header_up X-Forwarded-For {remote_host}
    header_up X-Forwarded-Proto {scheme}
  }
}

# ─── HTTP → HTTPS redirect (all hosts) ───────────────────────────────────────
:80 {
  redir https://{host}{uri} permanent
}

# ─── Optional: admin panel on a dedicated subdomain ─────────────────────────
# Uncomment and replace if you want a fixed admin hostname:
#
# admin.yourdomain.com {
#   reverse_proxy localhost:5000
# }
